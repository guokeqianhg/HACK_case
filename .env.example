# AI 测试官 · EdgeOne Makers 部署配置
# 复制本文件为 .env（.env 已被 gitignore，不会提交到仓库）

# ---------- EdgeOne Makers 内置模型网关（平台自动注入，留空即可）----------
# 部署时 CLI 会自动拉取真实值注入；本地 edgeone makers dev 也会带上来。
# 引擎优先用此网关（免费额度）跑「理解变更 / 根因推理」。
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=
# 可选：指定内置模型名（默认 @makers/deepseek-v4-flash）
AI_GATEWAY_MODEL=

# ---------- 引擎项目仓库地址（Makers 沙箱克隆用 · 部署关键）----------
# Makers 沙箱是空白环境，运行时需 git clone 本项目（引擎 + sample-app + 演示分支）进去才能跑。
# 把整个项目推到「公开」git 仓库后填这里（本地 dev 用），线上用 `edgeone makers env set PROJECT_REPO_URL <url>`。
# 必须公开可 clone；内网/私有仓库沙箱访问不到。评审测自己仓库时走前端「公开仓库 URL」输入框（引擎 --repo-url）。
PROJECT_REPO_URL=

# ---------- 可选：自定义 LLM（覆盖平台内置网关）----------
# 若不想用平台内置模型，可填自己的 OpenAI 兼容端点；引擎会优先 LLM_*/OPENAI_*。
OPENAI_API_KEY=""
OPENAI_BASE_URL="http://v2.open.venus.oa.com/llmproxy"
OPENAI_MODEL="kimi-k2.5"
# 可选：判定类快模型（语义理解 / 覆盖度 / 需求审计 / 自适应旁白）。不填则共用上面的推理模型。
# 配置后，这些"判定类"轻任务会从 23s/次 降到几秒，且不影响根因推理/测试生成用的推理模型。
# 例：OPENAI_FAST_MODEL="deepseek-chat"

# ---------- 场景 A · PR/MR 自动回写闭环（可选）----------
# 配置后，加 --pr <MR的IID> 运行即可在工蜂(TGit) MR 下自动评论测试结果；
# 未配置则优雅降级为写 report/pr-comment.md（dry-run），离线 Demo 不受影响。
# TGIT_TOKEN=""                                   # 工蜂 Private-Token
# TGIT_API_BASE="https://git.woa.com/api/v3"      # 工蜂 REST API 基址（默认即此值）
# 项目定位：优先 --pr-project owner/repo，否则自动从 git remote.origin.url 推断

# ---------- 场景 B · TAPD 需求/缺陷直连（可选）----------
# 配置后，加 --story <需求ID> 或 --bug <缺陷ID> 运行即可让 AI 测试官直接从 TAPD REST 拉需求/缺陷，
# 无需宿主 MCP 取回再写文件（与场景 A 直连工蜂同构）；未配置则回退本地 --requirement 文件。
# TAPD_API_USER=""                                  # TAPD API 账号
# TAPD_API_PASSWORD=""                              # TAPD API 密码
# TAPD_WORKSPACE_ID=""                              # TAPD 项目空间 ID（必填，定位需求/缺陷所属项目）
# TAPD_API_BASE="https://api.tapd.cn"               # TAPD Open API 基址（默认即此值）
