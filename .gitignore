report/.officer-last-message.md
report/.mcp-diff.txt
report/.mcp-req*.json
report/.mcp-req*.md
report/pr-comment.md
report/*.log
report/*.txt
# 实时看板事件流（运行时产物，看板服务器本身 report/live-server.mjs 保留追踪）
report/.live-*.ndjson
agent/.aio.out.txt
agent/.debug-test.txt
agent/.debug-smoke.txt
agent/.debug-out.txt
# 任何以 . 开头的一次性调试/探针脚本，均为开发期临时产物，不纳入版本库
agent/.*.mjs
agent/.*.js

# 示例应用临时输出
sample-app/.testout.txt
sample-app/.bugtest.txt
sample-app/.bugsmoke.txt
sample-app/test-results/

